---
import { personal } from "../data/personal";
---

<a class="skip-link" href="#main-content">Skip to content</a>
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${personal.name} homepage`}>
      <span class="brand-mark" aria-hidden="true">DM</span>
      <span>{personal.shortName}</span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      <a href="/">Home</a>
      <a href="/projects/autonomous-driving/">Case study</a>
      <a href="/portfolio-print/">A4 preview</a>
      <a href={personal.githubProfile} target="_blank" rel="noreferrer">GitHub</a>
    </nav>

    <details class="mobile-nav">
      <summary>Menu</summary>
      <nav aria-label="Mobile navigation">
        <a href="/">Home</a>
        <a href="/projects/autonomous-driving/">Case study</a>
        <a href="/portfolio-print/">A4 preview</a>
        <a href={personal.githubProfile} target="_blank" rel="noreferrer">GitHub</a>
      </nav>
    </details>
  </div>
</header>
