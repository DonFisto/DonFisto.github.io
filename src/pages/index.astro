---
import BaseLayout from "../layouts/BaseLayout.astro";
import BadgeList from "../components/BadgeList.astro";
import ContributionCard from "../components/ContributionCard.astro";
import EvidenceMedia from "../components/EvidenceMedia.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { personal } from "../data/personal";
import {
  architectureSummary,
  claims,
  contributions,
  heroMedia,
  project,
  technologies,
} from "../data/autonomousDriving";

const verifiedClaims = claims.filter((claim) => claim.publishable).slice(0, 4);
---

<BaseLayout
  title={`${personal.name} | Autonomous-Driving & Robotics Portfolio`}
  description={`Engineering portfolio of ${personal.name}, focused on ROS2 perception, CARLA, computer vision and local mapping.`}
>
  <main id="main-content">
    <section class="hero-section">
      <div class="container hero-layout">
        <div class="hero-copy">
          <p class="eyebrow">{personal.name}</p>
          <h1>Autonomous-driving perception, from pixels to local maps.</h1>
          <p class="hero-summary">{project.summary}</p>
          <p class="ownership">{project.ownership}</p>
          <div class="button-row">
            <a class="button button-primary" href={project.caseStudyPath}>View engineering case study</a>
            <a class="button button-secondary" href={project.repository} target="_blank" rel="noreferrer">Open repository</a>
            <a class="text-link" href={`mailto:${personal.email}`}>Email Daniel</a>
          </div>
          <BadgeList items={technologies.slice(0, 7).map((technology) => technology.name)} />
        </div>
        <div class="hero-visual">
          <EvidenceMedia media={heroMedia} priority />
          <div class="signal-strip" aria-label="Project stages">
            <span>Perception</span><span>Fusion</span><span>Occupancy</span><span>Mapping</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-surface" id="evidence">
      <div class="container">
        <SectionHeader
          eyebrow="Verified engineering scope"
          title="A complete prototype progression, not a single model demo"
          description="The work connects model development, dataset engineering, ROS2 integration, relative-depth reasoning and local mapping."
        />
        <div class="evidence-grid">
          {verifiedClaims.map((claim) => (
            <article class="evidence-card">
              <span class="status-dot" aria-hidden="true"></span>
              <p>{claim.text}</p>
              {claim.caveat && <small>{claim.caveat}</small>}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="system-scope">
      <div class="container">
        <SectionHeader
          eyebrow="System scope"
          title="Perception → fusion → occupancy → mapping"
          description="Each transition is implemented as an explicit robotics subsystem with observable ROS2 interfaces."
        />
        <ol class="homepage-system-flow">
          {architectureSummary.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{step}</p>
            </li>
          ))}
        </ol>
        <div class="homepage-contribution-grid">
          {contributions.map((contribution) => <ContributionCard contribution={contribution} />)}
        </div>
      </div>
    </section>

    <section class="section section-surface" id="profile">
      <div class="container profile-grid">
        <div>
          <SectionHeader
            eyebrow="Academic profile"
            title="Mathematics, computer science and applied autonomy"
            description={personal.availability}
          />
          <dl class="metadata-list">
            <div><dt>Degree</dt><dd>{personal.academicProfile}</dd></div>
            <div><dt>University</dt><dd>{personal.university}</dd></div>
            <div><dt>Graduation</dt><dd>{personal.expectedGraduation}</dd></div>
            <div><dt>Exchange</dt><dd>{personal.exchange}</dd></div>
          </dl>
        </div>
        <aside class="language-panel" aria-labelledby="languages-title">
          <h3 id="languages-title">Languages</h3>
          <ul>
            {personal.languages.map((item) => (
              <li><span>{item.language}</span><strong>{item.level}</strong></li>
            ))}
          </ul>
        </aside>
      </div>
    </section>

    <section class="section section-cta">
      <div class="container cta-panel">
        <div>
          <p class="eyebrow">Technical case study</p>
          <h2>Inspect the architecture, ROS2 interfaces, engineering methods and documented limitations.</h2>
        </div>
        <div class="button-row">
          <a class="button button-primary" href={project.caseStudyPath}>Explore the project</a>
          <a class="button button-secondary" href="/portfolio-print/">Preview the A4 portfolio</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
